# Exemplo de variáveis de ambiente — copie para .env e preencha com valores reais.
# NUNCA commite o arquivo .env com valores reais.

# ============================================================
# Ambiente de execução
# ============================================================
GOVERNANCE_ENV=dev                  # dev | staging | prod

# ============================================================
# Ponto de extensão: LLM real (opcional)
# Por padrão, os exemplos usam o agente simulado (mock).
# Descomente e preencha para conectar um LLM real.
# ============================================================
# LLM_PROVIDER=openai               # openai | anthropic | azure
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...

# ============================================================
# Configuração do runtime de governança
# ============================================================
GOVERNANCE_AUDIT_DIR=audit_logs     # diretório onde os logs JSONL são gravados
GOVERNANCE_KILL_SWITCH_FILE=.kill_switch  # arquivo que ativa o kill switch global

# ============================================================
# Aprovação humana (HITL)
# ============================================================
# AUTO_APPROVE=false                # true apenas em testes automatizados
# APPROVAL_TIMEOUT_SECONDS=300
